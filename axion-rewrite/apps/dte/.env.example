DATABASE_URL="postgresql://user:password@localhost:5432/axion"
JWT_SECRET="change-me-in-production"
PORT=3004
COD_EMPRESA=1
COD_SUCURSAL=1

# Certificado digital SII (PEM)
SII_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
SII_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Ambiente SII: 'certificacion' | 'produccion'
SII_AMBIENTE=certificacion
