{
  "name": "@optimind/pos",
  "version": "1.0.0",
  "private": true,
  "description": "Módulo POS — Caja: escaneo de QR, cobro, descuento de stock",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only server/src/index.ts",
    "dev:client": "vite client",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build client",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "@optimind/database": "workspace:*",
    "@optimind/shared": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/sensible": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.0",
    "jsqr": "^1.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "concurrently": "^9.0.0",
    "ts-node-dev": "^2.0.0"
  }
}
